GOOGLE_API_KEY=your_google_ai_studio_key_here

# Opsiyonel: orchestration/tek akis icin chat modeli (yoksa gemini-2.5-flash)
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Opsiyonel: Gemini embedding free-tier throttle (saniye / istek araligi). Varsayilan ~0.62
# GEMINI_EMBED_MIN_INTERVAL_S=0.62
# Opsiyonel: tek istekte gonderilecek metin sayisi (batchEmbedContents). Varsayilan 100.
# GEMINI_EMBED_BATCH_SIZE=100
# Ucretli planda hiz icin throttle'u kapat: GEMINI_EMBED_NO_THROTTLE=1

# Opsiyonel: Planner adimini LLM ile yap (varsayilan kapali; heuristic kullanilir).
# Free-tier'da chat kotasi (gemini-2.5-flash icin gunluk 20 istek) hizlica dolar;
# kapali birakirsan tam makalede bolum basina sadece 1 LLM cagrisi (Writer) yapilir.
# GEMINI_PLANNER_LLM=1

# Opsiyonel: IEEE Word sablonu (.docx) tam yolu — yoksa docs/templates/ConferenceTemplateIEEE.docx denenir
# IEEE_DOCX_TEMPLATE=C:\path\to\ConferenceTemplateIEEE.docx
